{
  "Repository": {
    "Directory": "data",
    "ConnectionString": "Data Source=data/listacompra.db",
    "DropData": false,
    "SeedData": true
  },
  "Cache": {
    "Size": 100,
    "Enabled": true
  },
  "Logging": {
    "File": {
      "Enabled": true,
      "Directory": "logs",
      "RetainDays": 7,
      "Level": "Information"
    },
    "Console": {
      "Enabled": true,
      "Level": "Debug"
    }
  }
}
