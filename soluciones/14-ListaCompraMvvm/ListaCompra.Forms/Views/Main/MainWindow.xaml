<Window x:Class="ListaCompra.Forms.Views.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="🛒 Lista de la Compra - Con FormData" Height="550" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Icon="/Resources/app-icon.ico"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <DockPanel>
        <!-- Barra de título -->
        <materialDesign:ColorZone Mode="PrimaryMid" DockPanel.Dock="Top" Padding="10">
            <TextBlock Text="🛒 Lista de la Compra" 
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       VerticalAlignment="Center"/>
        </materialDesign:ColorZone>

        <!-- Menú -->
        <Menu Background="Transparent" DockPanel.Dock="Top">
            <MenuItem Header="Archivo">
                <MenuItem Header="Importar" Command="{Binding ImportarCommand}">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Import"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Exportar" Command="{Binding ExportarCommand}">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Export"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Salir" Command="{Binding CerrarCommand}">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="ExitToApp"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Ayuda">
                <MenuItem Header="Acerca de" Click="AcercaDe_Click">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Information"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Buscador -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox materialDesign:HintAssist.Hint="Buscar producto..."
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding Busqueda, UpdateSourceTrigger=PropertyChanged}"/>
                
                <Button Grid.Column="1" Content="Limpiar" 
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="10,0,0,0"
                        Command="{Binding LimpiarBusquedaCommand}"/>
            </Grid>

            <!-- Formulario añadir (CON FORMDATA + IDATAERRORINFO) -->
            <materialDesign:Card Grid.Row="1" UniformCornerRadius="8" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Nombre con validación -->
                    <TextBox Grid.Column="0" 
                             materialDesign:HintAssist.Hint="Nombre del producto"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,10,0"
                             Text="{Binding FormData.Nombre, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
                    
                    <!-- Cantidad con validación -->
                    <TextBox Grid.Column="1" 
                             materialDesign:HintAssist.Hint="Cantidad"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,10,0"
                             Text="{Binding FormData.Cantidad, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
                    
                    <!-- Precio con validación -->
                    <TextBox Grid.Column="2" 
                             materialDesign:HintAssist.Hint="Precio"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,10,0"
                             Text="{Binding FormData.Precio, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
                    
                    <!-- Botón Añadir: se habilita solo si el formulario es válido -->
                    <Button Grid.Column="3" Content="➕ Añadir" 
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding AñadirCommand}"/>
                    
                    <!-- Botón Limpiar -->
                    <Button Grid.Column="4" Content="Limpiar" 
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="10,0,0,0"
                            Command="{Binding LimpiarFormularioCommand}"/>
                </Grid>
            </materialDesign:Card>

            <!-- Lista productos -->
            <ListBox Grid.Row="2"
                     ItemsSource="{Binding Productos}"
                     SelectedItem="{Binding ProductoSeleccionado}"
                     Style="{StaticResource MaterialDesignListBox}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <CheckBox Grid.Column="0" IsChecked="{Binding EstaComprado}" 
                                      VerticalAlignment="Center"
                                      Style="{StaticResource MaterialDesignCheckBox}"
                                      Command="{Binding DataContext.MarcarCompradoCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                      CommandParameter="{Binding}"/>
                            
                            <TextBlock Grid.Column="1" Text="{Binding Nombre}" 
                                       VerticalAlignment="Center" FontSize="14"/>
                            
                            <TextBlock Grid.Column="2" 
                                       Text="{Binding StringFormat='x{0}'}" 
                                       VerticalAlignment="Center" Foreground="Gray"/>
                            
                            <TextBlock Grid.Column="3" 
                                       Text="{Binding Total, StringFormat='{}{0:C2}'}" 
                                       VerticalAlignment="Center" FontWeight="Bold"/>
                            
                            <Button Grid.Column="4" Content="🗑️" 
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Foreground="#f44336"
                                    Command="{Binding DataContext.EliminarCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Pie -->
            <materialDesign:Card Grid.Row="3" UniformCornerRadius="8" Padding="15" Margin="0,15,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Total}" 
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}" 
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Mensaje}" 
                                   Foreground="Gray" Margin="20,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Button Grid.Column="1" Content="Cerrar" 
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding CerrarCommand}"/>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </DockPanel>
</Window>
