<Window x:Class="StarWars.Views.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
        xmlns:controls="clr-namespace:StarWars.Controls"
        xmlns:converters="clr-namespace:StarWars.Converters"
        xmlns:config="clr-namespace:StarWars.Config"
        Title="Star Wars: Clone Wars" Height="580" Width="920"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#0a0a0a"
        Icon="/Resources/app-icon.ico">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>

        <Style x:Key="StarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="#f5c518"/>
            <Setter Property="BorderBrush" Value="#f5c518"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="35,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#f5c518"/>
                                <Setter Property="Foreground" Value="#0a0a0a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#c4a210"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#333"/>
                                <Setter Property="Foreground" Value="#666"/>
                                <Setter Property="BorderBrush" Value="#444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Menu -->
        <Menu DockPanel.Dock="Top" Background="#1a1a2e" Height="30">
            <MenuItem Padding="10,4" FontSize="13">
                <MenuItem.Header>
                    <TextBlock Text="Archivo" Foreground="#f5c518" FontWeight="SemiBold"/>
                </MenuItem.Header>
            <MenuItem Header="Salir" Click="MenuSalir_Click" Padding="8,4" FontSize="13">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ExitToApp" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Ayuda" Padding="10,4" FontSize="13">
                <MenuItem Header="Acerca de Star Wars DAW" Click="MenuAcercaDe_Click" Padding="8,4" FontSize="13">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Information" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Padding="10,4" FontSize="13">
                <MenuItem.Header>
                    <TextBlock Text="Ayuda" Foreground="#f5c518" FontWeight="SemiBold"/>
                </MenuItem.Header>
                <MenuItem Header="Acerca de Star Wars DAW" Click="MenuAcercaDe_Click" Padding="8,4" FontSize="13">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Information" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Panel izquierdo: Controles -->
            <Border Grid.Column="0" Background="#16213e" BorderBrush="#f5c518" BorderThickness="2" CornerRadius="10" Padding="20" Margin="0,0,10,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Image Source="/Resources/app-icon.ico" Width="55" Height="55" Stretch="Uniform"/>
                        <TextBlock Text="Star Wars" FontSize="22" FontWeight="Bold" Foreground="#f5c518" VerticalAlignment="Center" Margin="10,0,0,0" FontFamily="Consolas"/>
                    </StackPanel>

                    <Border Height="2" Background="#333" Margin="0,0,0,15" CornerRadius="1"/>

                    <!-- Spinners -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Dimensión:" HorizontalAlignment="Right" Margin="0,0,10,8" VerticalAlignment="Center" Foreground="#f5c518" FontWeight="SemiBold"/>
                        <controls:SpinnerControl Grid.Row="0" Grid.Column="1" Minimum="{x:Static config:Configuration.MinDimension}" Maximum="{x:Static config:Configuration.MaxDimension}" Value="{Binding Dimension}" Height="30" Margin="0,0,0,8"
                                                 IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Droides:" HorizontalAlignment="Right" Margin="0,0,10,8" VerticalAlignment="Center" Foreground="#f5c518" FontWeight="SemiBold"/>
                        <controls:SpinnerControl Grid.Row="1" Grid.Column="1" Minimum="{x:Static config:Configuration.MinDroides}" Maximum="{x:Static config:Configuration.MaxDroides}" Value="{Binding NumDroides}" Height="30" Margin="0,0,0,8"
                                                 IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Tiempo (s):" HorizontalAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#f5c518" FontWeight="SemiBold"/>
                        <controls:SpinnerControl Grid.Row="2" Grid.Column="1" Minimum="{x:Static config:Configuration.MinTiempo}" Maximum="{x:Static config:Configuration.MaxTiempo}" Value="{Binding TiempoMax}" Height="30"
                                                 IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"/>
                    </Grid>

                    <!-- Valores -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <TextBlock Foreground="#e0e0e0" FontSize="13">
                            <Run Text="Dim: "/>
                            <Run Text="{Binding Dimension}" FontWeight="Bold" Foreground="#f5c518"/>
                            <Run Text=" | Droides: "/>
                            <Run Text="{Binding NumDroides}" FontWeight="Bold" Foreground="#f5c518"/>
                            <Run Text=" | Tiempo: "/>
                            <Run Text="{Binding TiempoMax}" FontWeight="Bold" Foreground="#f5c518"/>
                            <Run Text="s"/>
                        </TextBlock>
                    </StackPanel>

                    <Button Content="⚔ Comenzar" Style="{StaticResource StarButtonStyle}" HorizontalAlignment="Center" Margin="0,0,0,15"
                            Command="{Binding IniciarCommand}"
                            IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"/>

                    <Image Source="/Resources/images/rd2d2-guru.png" Width="100" Height="130" HorizontalAlignment="Right" Stretch="Uniform" Opacity="0.8"/>
                </StackPanel>
            </Border>

            <!-- Panel derecho: Operación, stats, cuadrante, progreso -->
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Operación -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Operación:" FontWeight="Bold" Foreground="#f5c518" Margin="0,0,0,5" FontSize="14"/>
                    <TextBox x:Name="TextOperacion" Height="90" IsReadOnly="True"
                             Text="{Binding Operacion, Mode=OneWay}"
                             FontFamily="Consolas" FontSize="11"
                             Background="#0f1a30" Foreground="#d7cc00"
                             BorderBrush="#3B82C4" BorderThickness="1"
                             VerticalScrollBarVisibility="Auto" Padding="5"/>
                </StackPanel>

                <!-- Stats -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,5">
                    <Border Background="#0f1a30" BorderBrush="#3B82C4" BorderThickness="1" CornerRadius="6" Padding="10,5" Margin="0,0,8,0">
                        <TextBlock Foreground="#d7cc00" FontSize="13">
                            <Run Text="Disparos: " Foreground="#f5c518" FontWeight="SemiBold"/>
                            <Run Text="{Binding Disparos}" FontWeight="Bold" FontSize="15"/>
                        </TextBlock>
                    </Border>
                    <Border Background="#0f1a30" BorderBrush="#3B82C4" BorderThickness="1" CornerRadius="6" Padding="10,5" Margin="0,0,8,0">
                        <TextBlock Foreground="#d7cc00" FontSize="13">
                            <Run Text="Aciertos: " Foreground="#f5c518" FontWeight="SemiBold"/>
                            <Run Text="{Binding Aciertos}" FontWeight="Bold" FontSize="15"/>
                        </TextBlock>
                    </Border>
                    <Border Background="#0f1a30" BorderBrush="#3B82C4" BorderThickness="1" CornerRadius="6" Padding="10,5">
                        <TextBlock Foreground="#d7cc00" FontSize="13">
                            <Run Text="Muertos: " Foreground="#f5c518" FontWeight="SemiBold"/>
                            <Run Text="{Binding Muertos}" FontWeight="Bold" FontSize="15"/>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- Cuadrante -->
                <StackPanel Grid.Row="2" Margin="0,5,0,5">
                    <TextBlock Text="Cuadrante:" FontWeight="Bold" Foreground="#f5c518" Margin="0,0,0,5" FontSize="14"/>
                    <TextBox x:Name="TextCuadrante" IsReadOnly="True"
                             Text="{Binding Cuadrante, Mode=OneWay}"
                             FontFamily="Cascadia Code, Consolas, Segoe UI Emoji" FontSize="16"
                             Background="#0f1a30" Foreground="#d7cc00"
                             BorderBrush="#3B82C4" BorderThickness="1"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap" Padding="8"/>
                </StackPanel>

                <!-- Progreso -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock Text="Tiempo:" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#f5c518" FontWeight="SemiBold" FontSize="13"/>
                    <ProgressBar Width="350" Height="18" Minimum="0" Maximum="100"
                                 Value="{Binding Progreso}"
                                 Background="#0f1a30" Foreground="#f5c518"
                                 BorderBrush="#3B82C4" BorderThickness="1"/>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
