<Window x:Class="StarWars.Views.Dialog.AcercaDeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
        Title="Acerca De Star Wars" Height="220" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#0a0a0a"
        Icon="/Resources/app-icon.ico">

    <Border Background="#16213e" BorderBrush="#f5c518" BorderThickness="2" CornerRadius="10" Margin="15">
        <Grid Margin="25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" Source="/Resources/app-icon.ico" Width="90" Height="90" Margin="0,0,25,0"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Star Wars DAW" FontSize="22" FontWeight="Bold" Foreground="#f5c518" FontFamily="Consolas"/>
                <TextBlock Text="Programación 1º DAW" FontSize="14" Foreground="#e0e0e0" Margin="0,4,0,15"/>
                <TextBlock FontSize="13" Foreground="#e0e0e0">
                    <Run Text="GitHub: " FontWeight="SemiBold"/>
                    <Hyperlink NavigateUri="https://github.com/joseluisgs" RequestNavigate="Hyperlink_RequestNavigate">
                        joseluisgs
                    </Hyperlink>
                    <InlineUIContainer BaselineAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Github" Width="18" Height="18" Margin="5,0,0,0"/>
                    </InlineUIContainer>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</Window>
