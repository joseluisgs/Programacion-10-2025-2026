<Window x:Class="StarWars.Views.Dialog.AcercaDeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acerca De Star Wars" Height="155" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#e7e7e7">

    <Grid Margin="10">
        <!-- Imagen del droide -->
        <Image Source="/Resources/icons/app.png" Width="110" Height="110" 
               HorizontalAlignment="Left" VerticalAlignment="Top" Stretch="Uniform"/>
        
        <!-- Información -->
        <StackPanel Margin="130,15,0,0">
            <TextBlock Text="Star Wars DAW" FontSize="21" FontWeight="Bold" HorizontalAlignment="Left"/>
            <TextBlock Text="Programación 1º DAW" FontSize="16" Margin="0,5,0,0"/>
            
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock>
                    <Hyperlink x:Name="linkGitHub" FontSize="16" 
                               NavigateUri="https://github.com/joseluisgs"
                               RequestNavigate="LinkGitHub_RequestNavigate">
                        GitHub
                    </Hyperlink>
                </TextBlock>
                <Image Source="/Resources/icons/github.png" Width="30" Height="30" 
                       Margin="5,0,0,0" Stretch="Uniform"/>
            </StackPanel>
        </StackPanel>
        
        <!-- Imagen R2D2 -->
        <Image Source="/Resources/images/rd2d2-guru.png" Width="64" Height="81" 
               HorizontalAlignment="Right" VerticalAlignment="Bottom" 
               Stretch="Uniform" Margin="0,0,10,10"/>
    </Grid>
</Window>
