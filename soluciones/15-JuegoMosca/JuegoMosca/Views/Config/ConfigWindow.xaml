<Window x:Class="JuegoMosca.Views.Config.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="La Mosca - Configuración" Height="350" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#f5f5f5"
        Icon="/Resources/icons/app.png">

    <DockPanel>
        <!-- Menu -->
        <Menu DockPanel.Dock="Top" Background="#4a90d9">
            <MenuItem Header="Archivo" Foreground="White">
                <MenuItem Header="Salir" Click="MenuSalir_Click">
                    <MenuItem.Icon>
                        <Image Source="/Resources/icons/exit.png" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Ayuda" Foreground="White">
                <MenuItem Header="Acerca de" Click="MenuAcercaDe_Click">
                    <MenuItem.Icon>
                        <Image Source="/Resources/icons/about.png" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Contenido principal -->
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Título con imagen -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,30">
                <Image Source="/Resources/icons/app.png" Width="69" Height="75" Stretch="Uniform"/>
                <TextBlock Text="La Mosca" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Margin="15,0,0,0"/>
            </StackPanel>

            <!-- Panel de configuración -->
            <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="30">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Dimensión:" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,15"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                            <Slider x:Name="SliderDimension" Width="120" Minimum="3" Maximum="10" Value="{Binding Dimension}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Dimension, StringFormat={}{0}x{0}}" Width="40" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Intentos:" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,15"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                            <Slider x:Name="SliderIntentos" Width="120" Minimum="1" Maximum="20" Value="{Binding Intentos}" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Intentos}" Width="40" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <Button Content="Comenzar" Margin="0,30,0,0" Padding="30,10" HorizontalAlignment="Center"
                            Background="#4a90d9" Foreground="White" FontWeight="Bold"
                            Command="{Binding ComenzarCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
