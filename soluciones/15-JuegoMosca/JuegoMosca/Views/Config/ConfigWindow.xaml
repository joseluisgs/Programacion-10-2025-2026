<Window x:Class="JuegoMosca.Views.Config.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
        xmlns:controls="clr-namespace:JuegoMosca.Controls"
        Title="La Mosca - Configuración" Height="450" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#f0f2f5"
        Icon="/Resources/app-icon.ico">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4a90d9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="45,14"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#357abd"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2c6aa0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Menu -->
        <Menu DockPanel.Dock="Top" Background="White" Height="32">
            <Menu.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="8" ShadowDepth="1" Direction="270"/>
            </Menu.Effect>
            <MenuItem Header="Archivo" Padding="12,6" FontSize="13">
                <MenuItem Header="Salir" Click="MenuSalir_Click" Padding="10,5" FontSize="13">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ExitToApp" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Ayuda" Padding="12,6" FontSize="13">
                <MenuItem Header="Acerca de Mosca DAW" Click="MenuAcercaDe_Click" Padding="10,5" FontSize="13">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Information" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Contenido principal -->
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Título con imagen -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Image Source="/Resources/app-icon.ico" Width="55" Height="55" Stretch="Uniform"/>
                <TextBlock Text="La Mosca" FontSize="28" FontWeight="Bold" Foreground="#2d3436" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>

            <!-- Panel de configuración -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="30">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="15" ShadowDepth="3" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Dimensión:" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,12" FontWeight="SemiBold" Foreground="#495057"/>
                        <controls:SpinnerControl Grid.Row="0" Grid.Column="1" Minimum="3" Maximum="10" Value="{Binding Dimension}" Height="34" Margin="0,0,0,12"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Intentos:" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="SemiBold" Foreground="#495057"/>
                        <controls:SpinnerControl Grid.Row="1" Grid.Column="1" Minimum="1" Maximum="20" Value="{Binding Intentos}" Height="34"/>
                    </Grid>

                    <Button Content="▶ Comenzar" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center"
                            Command="{Binding ComenzarCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
