<Window x:Class="JuegoMosca.Views.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
        xmlns:controls="clr-namespace:JuegoMosca.Controls"
        xmlns:converters="clr-namespace:JuegoMosca.Converters"
        Title="La Mosca: El Juego" Height="490" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#f0f2f5"
        Icon="/Resources/app-icon.ico">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>

        <!-- Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4a90d9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="35,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#357abd"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2c6aa0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#b0b0b0"/>
                                <Setter Property="Foreground" Value="#e0e0e0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6c757d"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="35,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5a6268"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4e555b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="15" ShadowDepth="3" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Menu -->
        <Menu DockPanel.Dock="Top" Background="White" Height="32">
            <Menu.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="8" ShadowDepth="1" Direction="270"/>
            </Menu.Effect>
            <MenuItem Header="Archivo" Padding="12,6" FontSize="13">
                <MenuItem Header="Salir" Click="MenuSalir_Click" Padding="10,5" FontSize="13">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ExitToApp" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Ayuda" Padding="12,6" FontSize="13">
                <MenuItem Header="Acerca de Mosca DAW" Click="MenuAcercaDe_Click" Padding="10,5" FontSize="13">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Information" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Panel izquierdo: Controles -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="25" Margin="0,0,10,0">
                <StackPanel VerticalAlignment="Center">
                    <!-- Título -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,25">
                        <Image Source="/Resources/app-icon.ico" Width="45" Height="45" Stretch="Uniform"/>
                        <TextBlock Text="La Mosca" FontSize="22" FontWeight="Bold" Foreground="#2d3436" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- Separador -->
                    <Border Height="2" Background="#e9ecef" Margin="0,0,0,20" CornerRadius="1"/>

                    <!-- Spinners -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Fila:" HorizontalAlignment="Right" Margin="0,0,12,10" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#495057"/>
                        <controls:SpinnerControl Grid.Row="0" Grid.Column="1" Minimum="1" Maximum="{Binding Dimension}" Value="{Binding FilaSeleccionada}" Margin="0,0,0,10" Height="32"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Columna:" HorizontalAlignment="Right" Margin="0,0,12,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#495057"/>
                        <controls:SpinnerControl Grid.Row="1" Grid.Column="1" Minimum="1" Maximum="{Binding Dimension}" Value="{Binding ColumnaSeleccionada}" Height="32"/>
                    </Grid>

                    <!-- Botones -->
                    <Button Content="🎯 Golpear" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center"
                            Command="{Binding GolpearCommand}"
                            IsEnabled="{Binding IsTerminado, Converter={StaticResource InverseBooleanConverter}}"/>
                    
                    <Button Content="🔄 Otra partida" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Center" Margin="0,10,0,0"
                            Visibility="{Binding MostrarBotonOtraPartida, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Click="OtraPartida_Click"/>
                </StackPanel>
            </Border>

            <!-- Panel derecho: Cuadrante -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="20" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="Cuadrante" FontWeight="Bold" FontSize="16" Foreground="#2d3436" Margin="0,0,0,12"/>
                    <Border Background="#f8f9fa" CornerRadius="8" Padding="15" BorderBrush="#dee2e6" BorderThickness="1">
                        <TextBox Text="{Binding Cuadrante, Mode=OneWay}"
                                 FontFamily="Segoe UI Emoji, Segoe UI Symbol, Consolas" FontSize="18"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#2d3436"
                                 MinHeight="220"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                        <Border Background="#e9ecef" CornerRadius="20" Padding="15,8">
                            <TextBlock FontSize="14" Foreground="#495057">
                                <Run Text="Intentos: " FontWeight="SemiBold"/>
                                <Run Text="{Binding Golpes}" FontWeight="Bold" Foreground="#4a90d9" FontSize="16"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding Intentos}" FontWeight="Bold" Foreground="#4a90d9" FontSize="16"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
