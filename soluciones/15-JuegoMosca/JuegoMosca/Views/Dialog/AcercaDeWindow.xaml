<Window x:Class="JuegoMosca.Views.Dialog.AcercaDeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
        Title="Acerca De Mosca DAW" Height="220" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#f0f2f5"
        Icon="/Resources/app-icon.ico">

    <Border Background="White" CornerRadius="12" Margin="15">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="15" ShadowDepth="3" Direction="270"/>
        </Border.Effect>
        <Grid Margin="25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" Source="/Resources/app-icon.ico" Width="90" Height="90" Margin="0,0,25,0"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Mosca DAW" FontSize="22" FontWeight="Bold" Foreground="#2d3436"/>
                <TextBlock Text="Programación 1º DAW" FontSize="14" Foreground="#6c757d" Margin="0,4,0,15"/>
                <TextBlock FontSize="13" Foreground="#495057">
                    <Run Text="GitHub: " FontWeight="SemiBold"/>
                    <Hyperlink NavigateUri="https://github.com/joseluisgs" RequestNavigate="Hyperlink_RequestNavigate">
                        joseluisgs
                    </Hyperlink>
                    <InlineUIContainer BaselineAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Github" Width="18" Height="18" Margin="5,0,0,0"/>
                    </InlineUIContainer>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</Window>
