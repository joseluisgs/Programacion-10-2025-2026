<Window x:Class="Pokedex.Views.Dialog.AcercaDeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acerca de" Height="300" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#d2d2fa"
        Icon="/Resources/app-icon.ico">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Image Grid.Row="0" Source="/Resources/icons/pokedex.png" 
               Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" 
                   Text="Pokedex DAW" 
                   FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"
                   Foreground="#000d56"/>

        <TextBlock Grid.Row="2" 
                   Text="Versión 1.0.0&#x0a;&#x0a;Aplicación de gestión de Pokédex&#x0a;desarrollada en WPF con C#&#x0a;&#x0a;Desarrollado por Jose Luis GS"
                   TextAlignment="Center" 
                   Foreground="#000d56"
                   Margin="0,0,0,15"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Image Source="/Resources/icons/github.png" Width="20" Height="20" Margin="0,0,5,0"/>
            <TextBlock VerticalAlignment="Center">
                <Hyperlink NavigateUri="https://github.com/joseluisgs" 
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="#000d56">
                    github.com/joseluisgs
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <Button Grid.Row="5" Content="Cerrar" 
                Padding="20,10" 
                HorizontalAlignment="Center"
                Click="Cerrar_Click"
                Background="#ff7f7f" Foreground="White"/>
    </Grid>
</Window>
