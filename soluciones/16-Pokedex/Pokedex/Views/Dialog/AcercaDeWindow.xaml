<Window x:Class="Pokedex.Views.Dialog.AcercaDeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
        Title="Acerca de" Height="340" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1a1a2e"
        Icon="/Resources/app-icon.ico">

    <Window.Resources>
        <Style x:Key="AboutButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E3350C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#B8200A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFCB05"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="BorderBrush" Value="#CBA304"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#B8200A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#3B82C4" BorderThickness="2" CornerRadius="10">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Image Grid.Row="0" Source="/Resources/app-icon.ico"
                   Width="70" Height="70" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Grid.Row="1"
                       Text="POKEDEX"
                       FontSize="26" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,8"
                       Foreground="#FFCB05"
                       FontFamily="Consolas"/>

            <TextBlock Grid.Row="2"
                       Text="Versión 1.0.0&#x0a;&#x0a;Aplicación de gestión de Pokédex&#x0a;desarrollada en WPF con C#&#x0a;&#x0a;Desarrollado por Jose Luis GS"
                       TextAlignment="Center"
                       Foreground="#e0e0e0"
                       Margin="0,0,0,15"
                       FontSize="13"/>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                <iconPacks:PackIconMaterial Kind="Github" Width="18" Height="18" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBlock VerticalAlignment="Center" FontSize="13">
                    <Hyperlink NavigateUri="https://github.com/joseluisgs"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="#3B82C4">
                        github.com/joseluisgs
                    </Hyperlink>
                </TextBlock>
            </StackPanel>

            <Button Grid.Row="5" Content="Cerrar"
                    Style="{StaticResource AboutButtonStyle}"
                    HorizontalAlignment="Center"
                    Click="Cerrar_Click"/>
        </Grid>
    </Border>
</Window>
