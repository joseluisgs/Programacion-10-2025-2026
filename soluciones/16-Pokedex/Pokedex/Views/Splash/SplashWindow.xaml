<Window x:Class="Pokedex.Views.Splash.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cargando..." Height="320" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1a1a2e"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border BorderBrush="#3B82C4" BorderThickness="2" CornerRadius="12">
        <Grid>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="/Resources/app-icon.ico"
                       Width="100" Height="100"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

                 <TextBlock Text="POKEDEX"
                           FontSize="32" FontWeight="Bold"
                           Foreground="#FFCB05"
                           HorizontalAlignment="Center"
                           FontFamily="Consolas"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Cargando datos..."
                           FontSize="14"
                           Foreground="#a0a0b0"
                           HorizontalAlignment="Center"/>

                <ProgressBar IsIndeterminate="True"
                             Width="200" Height="6"
                             Margin="0,20,0,0"
                             Background="#0f1a30"
                             Foreground="#FFCB05"
                             BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
