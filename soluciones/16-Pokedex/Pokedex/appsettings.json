{
  "Repository": {
    "Directory": "data",
    "FileName": "pokedex.json",
    "SeedData": true,
    "DropData": false
  },
  "Cache": {
    "Size": 10,
    "Enabled": true
  },
  "Logging": {
    "File": {
      "Enabled": true,
      "Directory": "logs",
      "RetainDays": 7,
      "Level": "Information"
    },
    "Console": {
      "Enabled": true,
      "Level": "Debug"
    }
  }
}
