<Window x:Class="Enrutador.Views.Login.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inicio de Sesión" Height="300" Width="400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="INICIO DE SESIÓN" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock Text="Usuario:"/>
            <TextBox x:Name="TxtUsuario" Margin="0,5,0,10" Text="admin"/>
            <TextBlock Text="Contraseña:"/>
            <PasswordBox x:Name="TxtPassword" Margin="0,5,0,20"/>
            <Button x:Name="BtnLogin" Content="Entrar" Height="40" Click="BtnLogin_Click"/>
        </StackPanel>
    </Grid>
</Window>
