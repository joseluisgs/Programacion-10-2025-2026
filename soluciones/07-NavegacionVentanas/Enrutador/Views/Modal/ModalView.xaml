<Window x:Class="Enrutador.Views.Modal.ModalView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ventana Modal" Height="200" Width="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="¡Soy una ventana modal!" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <Button Content="Aceptar" Height="30" Click="BtnAceptar_Click"/>
        </StackPanel>
    </Grid>
</Window>
