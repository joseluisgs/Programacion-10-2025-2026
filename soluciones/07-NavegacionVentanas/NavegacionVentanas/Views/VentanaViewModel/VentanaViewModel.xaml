<!-- ============================================================ -->
<!-- VentanaViewModel.xaml - ViewModel compartido -->
<!-- ============================================================ -->
<!-- Esta ventana usa un ViewModel compartido con la ventana principal. -->

<Window x:Class="NavegacionVentanas.Views.VentanaViewModel.VentanaViewModel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ViewModel Compartido" Height="300" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="🔄 ViewModel Compartido"
                   FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Info del ViewModel -->
        <Border Grid.Row="1" Background="#e8f5e9" Padding="15" CornerRadius="5" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Datos del ViewModel:" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock x:Name="TxtMensaje" Text="{Binding Mensaje}"/>
                <TextBlock x:Name="TxtContador" Text="{Binding Contador, StringFormat='Contador: {0}'}" Margin="0,5,0,0"/>
                <TextBlock x:Name="TxtDatoCompartido" Text="{Binding DatoCompartido}" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Editar dato compartido -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Editar dato compartido:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtEditarDato" Padding="5"/>
            <Button Content="💾 Guardar" Padding="15,5" Margin="0,10,0,0"
                    Background="#2196F3" Foreground="White"
                    HorizontalAlignment="Left"
                    Click="BtnGuardar_Click"/>
        </StackPanel>

        <!-- Botones -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="➕ Incrementar" Padding="15,8" Margin="5"
                    Background="#4CAF50" Foreground="White"
                    Click="BtnIncrementar_Click"/>
            <Button Content="🔄 Reiniciar" Padding="15,8" Margin="5"
                    Background="#FF9800" Foreground="White"
                    Click="BtnReiniciar_Click"/>
            <Button Content="❌ Cerrar" Padding="15,8" Margin="5"
                    Background="#f44336" Foreground="White"
                    Click="BtnCerrar_Click"/>
        </StackPanel>

    </Grid>
</Window>
