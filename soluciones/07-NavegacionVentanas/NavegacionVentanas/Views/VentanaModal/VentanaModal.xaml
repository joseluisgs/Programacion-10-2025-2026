<!-- ============================================================ -->
<!-- VentanaModal.xaml - Ventana modal con DialogResult -->
<!-- ============================================================ -->
<!-- Esta ventana se abre con ShowDialog() y devuelve un resultado. -->
<!-- El usuario debe pulsar Aceptar o Cancelar. -->

<Window x:Class="NavegacionVentanas.Views.VentanaModal.VentanaModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ventana Modal" Height="200" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Contenido -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center">
            <TextBlock Text="📝 Esta es una ventana MODAL"
                       FontSize="16" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="No puedes interactuar con la ventana principal mientras esta esté abierta."
                       TextWrapping="Wrap" TextAlignment="Center"
                       Foreground="Gray"/>
        </StackPanel>

        <!-- Botones -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="✅ Aceptar" Padding="20,8" Margin="5"
                    Background="#4CAF50" Foreground="White"
                    Click="BtnAceptar_Click"/>
            <Button Content="❌ Cancelar" Padding="20,8" Margin="5"
                    Background="#f44336" Foreground="White"
                    Click="BtnCancelar_Click"/>
        </StackPanel>

    </Grid>
</Window>
