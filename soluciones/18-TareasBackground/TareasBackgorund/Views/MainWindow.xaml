<Window x:Class="TareasBackground.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Problema de Background - Tareas en Segundo Plano"
        Height="300" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#f5f5f5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="Ejemplo de Tareas en Segundo Plano"
                   FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Barra de progreso -->
        <ProgressBar Grid.Row="1"
                     Value="{Binding Progreso}"
                     Maximum="100"
                     Height="30"
                     Margin="0,0,0,20"/>

        <!-- Mensaje de estado -->
        <TextBlock Grid.Row="2"
                   Text="{Binding Mensaje}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"
                   TextWrapping="Wrap"/>

        <!-- Botones -->
        <StackPanel Grid.Row="3" VerticalAlignment="Center">
            <!-- Botón de tarea bloqueante (INCORRECTO) -->
            <Button Content="❌ Tarea Bloqueante (No usar)"
                    Command="{Binding EjecutarTareaBloqueanteCommand}"
                    IsEnabled="{Binding BotonHabilitado}"
                    Background="#ffcccc"
                    Padding="10" Margin="0,5"
                    ToolTip="Este botón bloquea la UI. ¡No usarlo en producción!"/>

            <!-- Botón de tarea no bloqueante (CORRECTO) -->
            <Button Content="✅ Tarea No Bloqueante (Recomendado)"
                    Command="{Binding EjecutarTareaNoBloqueanteCommand}"
                    IsEnabled="{Binding BotonHabilitado}"
                    Background="#ccffcc"
                    Padding="10" Margin="0,5"/>

            <!-- Botón de tarea async (MEJOR) -->
            <Button Content="🚀 Tarea Async/Await (Óptimo)"
                    Command="{Binding EjecutarTareaAsyncCommand}"
                    IsEnabled="{Binding BotonHabilitado}"
                    Background="#ccccff"
                    Padding="10" Margin="0,5"/>

            <!-- Botón de reiniciar -->
            <Button Content="🔄 Reiniciar"
                    Command="{Binding ReiniciarCommand}"
                    Padding="10" Margin="0,15,0,0"/>
        </StackPanel>

        <!-- Indicador de ejecución -->
        <TextBlock Grid.Row="4"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0">
            <Run Text="Estado: "/>
            <Run Text="{Binding EstaEjecutando}" FontWeight="Bold"/>
        </TextBlock>
    </Grid>
</Window>
