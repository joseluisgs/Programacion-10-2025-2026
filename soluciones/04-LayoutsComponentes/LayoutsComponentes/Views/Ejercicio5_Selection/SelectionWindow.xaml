<Window x:Class="LayoutsComponentes.Views.Ejercicio5_Selection.SelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Componentes de Selección" Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="☑️ Componentes de Selección" FontSize="18" 
                   FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- Componentes de selección -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                
                <!-- CheckBox: casilla de verificación -->
                <TextBlock Text="☑️ CheckBox" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <StackPanel Margin="0,0,0,15">
                    <!-- CheckBox normal de dos estados -->
                    <CheckBox x:Name="chkAcepto" Content="Acepto los términos y condiciones"
                              IsChecked="False" Checked="ChkAcepto_Changed" Unchecked="ChkAcepto_Changed"/>
                    
                    <!-- CheckBox de tres estados -->
                    <CheckBox x:Name="chkTodos" Content="Seleccionar todos"
                              IsThreeState="True" Margin="0,10,0,0"
                              Indeterminate="ChkTodos_Indeterminate"
                              Checked="ChkTodos_Checked" Unchecked="ChkTodos_Unchecked"/>
                    
                    <!-- Opciones que dependen del CheckBox "Seleccionar todos" -->
                    <StackPanel Margin="20,5,0,0">
                        <CheckBox x:Name="chkOpcion1" Content="Opción 1" IsChecked="True"/>
                        <CheckBox x:Name="chkOpcion2" Content="Opción 2" IsChecked="True"/>
                        <CheckBox x:Name="chkOpcion3" Content="Opción 3" IsChecked="True"/>
                    </StackPanel>
                </StackPanel>

                <!-- RadioButton: botones de opción exclusivos -->
                <TextBlock Text="🔘 RadioButton (Selección exclusiva)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Tamaño de camiseta:" Margin="0,0,0,5"/>
                    <!-- Todos con el mismo GroupName son mutuamente excluyentes -->
                    <RadioButton x:Name="rbTallaS" GroupName="Talla" Content="S" Margin="0,2"/>
                    <RadioButton x:Name="rbTallaM" GroupName="Talla" Content="M" IsChecked="True" Margin="0,2"/>
                    <RadioButton x:Name="rbTallaL" GroupName="Talla" Content="L" Margin="0,2"/>
                    <RadioButton x:Name="rbTallaXL" GroupName="Talla" Content="XL" Margin="0,2"/>
                    
                    <TextBlock Text="Color:" Margin="0,10,0,5"/>
                    <!-- Grupo independiente: diferente GroupName -->
                    <RadioButton x:Name="rbRojo" GroupName="Color" Content="Rojo" Margin="0,2"/>
                    <RadioButton x:Name="rbAzul" GroupName="Color" Content="Azul" IsChecked="True" Margin="0,2"/>
                    <RadioButton x:Name="rbVerde" GroupName="Color" Content="Verde" Margin="0,2"/>
                </StackPanel>

                <!-- ComboBox: lista desplegable -->
                <TextBlock Text="🔻 ComboBox (Lista desplegable)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="País:" Margin="0,0,0,5"/>
                    <!-- ComboBox con elementos definidos en XAML -->
                    <ComboBox x:Name="cmbPais" SelectedIndex="0" SelectionChanged="CmbPais_SelectionChanged">
                        <ComboBoxItem Content="España"/>
                        <ComboBoxItem Content="México"/>
                        <ComboBoxItem Content="Argentina"/>
                        <ComboBoxItem Content="Colombia"/>
                        <ComboBoxItem Content="Chile"/>
                    </ComboBox>
                    <TextBlock x:Name="lblPais" Text="Seleccionado: España" 
                               Foreground="Gray" FontSize="11" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- ListBox: lista de selección -->
                <TextBlock Text="📋 ListBox (Lista con selección)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Selecciona un lenguaje de programación:" Margin="0,0,0,5"/>
                    <!-- ListBox con SelectionMode -->
                    <ListBox x:Name="lstLenguajes" Height="120" 
                             SelectionMode="Single" SelectionChanged="LstLenguajes_SelectionChanged">
                        <ListBoxItem Content="C#"/>
                        <ListBoxItem Content="Python"/>
                        <ListBoxItem Content="JavaScript"/>
                        <ListBoxItem Content="Java"/>
                        <ListBoxItem Content="Kotlin"/>
                        <ListBoxItem Content="Swift"/>
                    </ListBox>
                    <TextBlock x:Name="lblLenguaje" Text="Seleccionado: (ninguno)" 
                               Foreground="Gray" FontSize="11" Margin="0,5,0,0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Panel de resultado y botón cerrar -->
        <StackPanel Grid.Row="2" Margin="0,15,0,0">
            <Border Background="#f0f0f0" Padding="10" CornerRadius="5">
                <TextBlock x:Name="txtResumen" TextWrapping="Wrap" FontSize="12"/>
            </Border>
            <Button Content="Cerrar" Height="35" Margin="0,10,0,0" Click="BtnCerrar_Click"/>
        </StackPanel>

    </Grid>
</Window>
