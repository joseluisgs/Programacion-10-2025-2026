<Window x:Class="LayoutsComponentes.Views.Ejercicio7_TabsExpander.TabsExpanderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tabs, Expander, GroupBox y más" Height="550" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            
            <!-- Título -->
            <TextBlock Text="🔶 Contenedores Especiales" FontSize="20" 
                       FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- ============================================================ -->
            <!-- TabControl: Pestañas -->
            <!-- ============================================================ -->
            <TextBlock Text="📑 TabControl (Pestañas)" FontSize="16" 
                       FontWeight="Bold" Margin="0,0,0,10"/>
            
            <TabControl Margin="0,0,0,20">
                <!-- Pestaña 1: General -->
                <TabItem Header="General">
                    <StackPanel Margin="15">
                        <TextBlock Text="Configuración general de la aplicación" 
                                   FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <CheckBox Content="Iniciar con Windows" Margin="0,5"/>
                        <CheckBox Content="Minimizar a la bandeja" Margin="0,5"/>
                        <CheckBox Content="Mostrar notificaciones" Margin="0,5"/>
                    </StackPanel>
                </TabItem>
                
                <!-- Pestaña 2: Apariencia -->
                <TabItem Header="Apariencia">
                    <StackPanel Margin="15">
                        <TextBlock Text="Opciones de apariencia" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <TextBlock Text="Tema:" Margin="0,5,0,5"/>
                        <ComboBox SelectedIndex="0">
                            <ComboBoxItem Content="Claro"/>
                            <ComboBoxItem Content="Oscuro"/>
                            <ComboBoxItem Content="Sistema"/>
                        </ComboBox>
                    </StackPanel>
                </TabItem>
                
                <!-- Pestaña 3: Avanzado (deshabilitada) -->
                <TabItem Header="Avanzado" IsEnabled="False">
                    <TextBlock Text="Próximamente..." Margin="15"/>
                </TabItem>
            </TabControl>

            <!-- ============================================================ -->
            <!-- Expander: Paneles expandibles -->
            <!-- ============================================================ -->
            <TextBlock Text="🔽 Expander (Paneles expandibles)" FontSize="16" 
                       FontWeight="Bold" Margin="0,0,0,10"/>
            
            <StackPanel Margin="0,0,0,20">
                <!-- Expander 1: expandido por defecto -->
                <Expander Header="📧 Configuración de correo" IsExpanded="True">
                    <StackPanel Margin="15,5,0,0">
                        <CheckBox Content="Activar notificaciones"/>
                        <CheckBox Content="Sincronizar automáticamente"/>
                        <CheckBox Content="Descargar adjuntos grandes"/>
                    </StackPanel>
                </Expander>
                
                <!-- Expander 2: contraído por defecto -->
                <Expander Header="🔒 Privacidad" IsExpanded="False">
                    <StackPanel Margin="15,5,0,0">
                        <CheckBox Content="No rastrear"/>
                        <CheckBox Content="Eliminar historial al cerrar"/>
                        <CheckBox Content="Bloquear seguimiento"/>
                    </StackPanel>
                </Expander>
                
                <!-- Expander 3 -->
                <Expander Header="⚡ Rendimiento">
                    <StackPanel Margin="15,5,0,0">
                        <CheckBox Content="Limitar uso de CPU"/>
                        <CheckBox Content="Modo de ahorro de energía"/>
                    </StackPanel>
                </Expander>
            </StackPanel>

            <!-- ============================================================ -->
            <!-- GroupBox: Grupo con borde y título -->
            <!-- ============================================================ -->
            <TextBlock Text="📦 GroupBox (Grupo con título)" FontSize="16" 
                       FontWeight="Bold" Margin="0,0,0,10"/>
            
            <GroupBox Header="Datos personales" Margin="0,0,0,20" Padding="15">
                <StackPanel>
                    <Label Content="_Nombre:" Target="{Binding ElementName=txtNombre}"/>
                    <TextBox x:Name="txtNombre" Margin="0,0,0,10"/>
                    <Label Content="_Email:" Target="{Binding ElementName=txtEmail2}"/>
                    <TextBox x:Name="txtEmail2" Margin="0,0,0,10"/>
                </StackPanel>
            </GroupBox>

            <!-- ============================================================ -->
            <!-- Border: Borde decorativo -->
            <!-- ============================================================ -->
            <TextBlock Text="⬜ Border (Bordes decorativos)" FontSize="16" 
                       FontWeight="Bold" Margin="0,0,0,10"/>
            
            <!-- Border con esquinas redondeadas y sombra -->
            <Border Background="White" BorderBrush="#DDDDDD" 
                    BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,10">
                <Border.Effect>
                    <!-- Sombra suave -->
                    <DropShadowEffect BlurRadius="12" Opacity="0.15" 
                                     ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="🎫 Tarjeta de contenido" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="Este es un ejemplo de tarjeta con borde redondeado y sombra." 
                               TextWrapping="Wrap" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Border como botón decorado -->
            <Border Background="LightBlue" CornerRadius="20" Padding="15,8" 
                    HorizontalAlignment="Left" Cursor="Hand" Margin="0,0,0,20">
                <TextBlock Text="Botón estilo píldora" Foreground="White" FontWeight="SemiBold"/>
            </Border>

            <!-- ============================================================ -->
            <!-- Separator: Línea divisoria -->
            <!-- ============================================================ -->
            <TextBlock Text="➖ Separator (Línea divisoria)" FontSize="16" 
                       FontWeight="Bold" Margin="0,0,0,10"/>
            
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Opción 1"/>
                <Separator Margin="0,8"/>
                <TextBlock Text="Opción 2"/>
                <Separator Margin="0,8"/>
                <TextBlock Text="Opción 3"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
