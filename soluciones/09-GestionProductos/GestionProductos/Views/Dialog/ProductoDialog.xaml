<!-- ============================================================ -->
<!-- ProductoDialog.xaml - Dialogo para anadir/editar productos -->
<!-- ============================================================ -->

<Window x:Class="GestionProductos.Views.Dialog.ProductoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Producto" Height="450" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Nombre -->
        <TextBlock Grid.Row="0" Grid.Column="0" 
                   Text="Nombre:" 
                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                   VerticalAlignment="Center" 
                   Margin="0,0,0,15"/>
        <TextBox x:Name="TxtNombre" Grid.Row="0" Grid.Column="1" 
                 materialDesign:HintAssist.Hint="Nombre del producto"
                 materialDesign:HintAssist.IsFloating="True"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                 Margin="0,0,0,15"/>

        <!-- Descripcion -->
        <TextBlock Grid.Row="1" Grid.Column="0" 
                   Text="Descripcion:" 
                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                   VerticalAlignment="Top" 
                   Margin="0,0,0,15"/>
        <TextBox x:Name="TxtDescripcion" Grid.Row="1" Grid.Column="1" 
                 materialDesign:HintAssist.Hint="Descripcion del producto"
                 materialDesign:HintAssist.IsFloating="True"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                 TextWrapping="Wrap" AcceptsReturn="True" Height="70"
                 Margin="0,0,0,15"/>

        <!-- Categoria -->
        <TextBlock Grid.Row="2" Grid.Column="0" 
                   Text="Categoria:" 
                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                   VerticalAlignment="Center" 
                   Margin="0,0,0,15"/>
        <ComboBox x:Name="CmbCategoria" Grid.Row="2" Grid.Column="1" 
                  materialDesign:HintAssist.Hint="Seleccionar categoria"
                  materialDesign:HintAssist.IsFloating="True"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}" 
                  IsEditable="True" Margin="0,0,0,15">
            <ComboBoxItem Content="Electronica"/>
            <ComboBoxItem Content="Muebles"/>
            <ComboBoxItem Content="Iluminacion"/>
            <ComboBoxItem Content="Almacenamiento"/>
            <ComboBoxItem Content="Accesorios"/>
        </ComboBox>

        <!-- Precio -->
        <TextBlock Grid.Row="3" Grid.Column="0" 
                   Text="Precio:" 
                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                   VerticalAlignment="Center" 
                   Margin="0,0,0,15"/>
        <TextBox x:Name="TxtPrecio" Grid.Row="3" Grid.Column="1" 
                 materialDesign:HintAssist.Hint="Precio"
                 materialDesign:HintAssist.IsFloating="True"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                 Margin="0,0,0,15"/>

        <!-- Stock -->
        <TextBlock Grid.Row="4" Grid.Column="0" 
                   Text="Stock:" 
                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                   VerticalAlignment="Center" 
                   Margin="0,0,0,15"/>
        <TextBox x:Name="TxtStock" Grid.Row="4" Grid.Column="1" 
                 materialDesign:HintAssist.Hint="Stock"
                 materialDesign:HintAssist.IsFloating="True"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                 Margin="0,0,0,15"/>

        <!-- Botones -->
        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Aceptar" 
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="4"
                    Margin="0,0,10,0" 
                    Click="BtnAceptar_Click">
                <Button.Background>
                    <SolidColorBrush Color="#4CAF50"/>
                </Button.Background>
            </Button>
            <Button Content="Cancelar" 
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    materialDesign:ButtonAssist.CornerRadius="4"
                    Click="BtnCancelar_Click"/>
        </StackPanel>
    </Grid>
</Window>
