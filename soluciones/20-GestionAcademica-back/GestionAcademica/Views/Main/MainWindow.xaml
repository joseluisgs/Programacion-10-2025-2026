<Window x:Class="GestionAcademica.Views.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        
        Title="Gestión Académica - DAW"
        Icon="pack://application:,,,/Resources/icons/app-icon.png"
        Width="1200"
        Height="800"
        WindowStartupLocation="CenterScreen"
        Closing="OnWindowClosing"
        Background="#1E1E1E"
        Foreground="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="#252525" Foreground="White" Padding="5">
            <MenuItem Header="_Archivo">
                <MenuItem Header="_Exportar datos..." Click="OnExportarClick"/>
                <MenuItem Header="_Importar datos..." Click="OnImportarClick"/>
                <Separator/>
                <MenuItem Header="_Crear backup..." Click="OnCrearBackupClick"/>
                <MenuItem Header="_Restaurar backup..." Click="OnRestaurarBackupClick"/>
                <Separator/>
                <MenuItem Header="_Salir" Click="OnSalirClick"/>
            </MenuItem>
            
            <MenuItem Header="_Personas">
                <MenuItem Header="_Estudiantes" Click="OnEstudiantesClick"/>
                <MenuItem Header="_Docentes" Click="OnDocentesClick"/>
            </MenuItem>
            
            <MenuItem Header="_Informes">
                <MenuItem Header="_Generar informe..." Click="OnInformesClick"/>
                <MenuItem Header="_Estadísticas" Click="OnGraficosClick"/>
            </MenuItem>
            
            <MenuItem Header="_Herramientas">
                <MenuItem Header="_Cambiar tema">
                    <MenuItem x:Name="MenuTemaOscuro" Header="Tema Oscuro" IsCheckable="True" IsChecked="True" Click="OnTemaOscuroClick"/>
                    <MenuItem x:Name="MenuTemaClaro" Header="Tema Claro" IsCheckable="True" IsChecked="False" Click="OnTemaClaroClick"/>
                </MenuItem>
                <MenuItem Header="_Configuración" Click="OnConfiguracionClick"/>
            </MenuItem>
            
            <MenuItem Header="_Ayuda">
                <MenuItem Header="_Acerca de" Click="OnAcercaDeClick"/>
            </MenuItem>
        </Menu>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#252525" BorderBrush="#333333" BorderThickness="0,0,1,0">
                <StackPanel Margin="10">
                    <TextBlock Text="NAVEGACIÓN" FontSize="12" FontWeight="Bold" Foreground="#888888" Margin="10,10,0,10"/>
                    
                    <Button Content="Dashboard" Click="OnDashboardClick" Margin="0,2" Padding="15,10" HorizontalContentAlignment="Left" Background="Transparent" Foreground="White" BorderThickness="0"/>
                    <Button Content="Estudiantes" Click="OnEstudiantesClick" Margin="0,2" Padding="15,10" HorizontalContentAlignment="Left" Background="Transparent" Foreground="White" BorderThickness="0"/>
                    <Button Content="Docentes" Click="OnDocentesClick" Margin="0,2" Padding="15,10" HorizontalContentAlignment="Left" Background="Transparent" Foreground="White" BorderThickness="0"/>
                    
                    <Separator Margin="10,15" Background="#333333"/>
                    
                    <TextBlock Text="HERRAMIENTAS" FontSize="12" FontWeight="Bold" Foreground="#888888" Margin="10,0,0,10"/>
                    
                    <Button Content="Informes" Click="OnInformesClick" Margin="0,2" Padding="15,10" HorizontalContentAlignment="Left" Background="Transparent" Foreground="White" BorderThickness="0"/>
                    <Button Content="Gráficos" Click="OnGraficosClick" Margin="0,2" Padding="15,10" HorizontalContentAlignment="Left" Background="Transparent" Foreground="White" BorderThickness="0"/>
                    <Button Content="Backups" Click="OnBackupClick" Margin="0,2" Padding="15,10" HorizontalContentAlignment="Left" Background="Transparent" Foreground="White" BorderThickness="0"/>
                    <Button Content="Import/Export" Click="OnImportExportClick" Margin="0,2" Padding="15,10" HorizontalContentAlignment="Left" Background="Transparent" Foreground="White" BorderThickness="0"/>
                    
                    <Separator Margin="10,15" Background="#333333"/>
                    
                    <TextBlock Text="APARIENCIA" FontSize="12" FontWeight="Bold" Foreground="#888888" Margin="10,0,0,10"/>
                    
                    <RadioButton x:Name="TemaOscuroRadio" Content="Tema Oscuro" IsChecked="True" Foreground="White" Margin="15,5" Checked="OnTemaOscuroChecked"/>
                    <RadioButton x:Name="TemaClaroRadio" Content="Tema Claro" Foreground="White" Margin="15,5" Checked="OnTemaClaroChecked"/>
                </StackPanel>
            </Border>

            <!-- Content Area -->
            <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="#252525" Foreground="#888888" Padding="5">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Listo" FontSize="12"/>
            </StatusBarItem>
            <Separator Background="#333333"/>
            <StatusBarItem>
                <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" FontSize="12" Foreground="#888888"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>