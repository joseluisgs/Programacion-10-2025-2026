<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ListaTareasAvalonia.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="ListaTareasAvalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Lista de Tareas - Avalonia"
        Width="600" Height="500"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <StackPanel Margin="20">
        <!-- Título -->
        <TextBlock Text="📝 Lista de Tareas - Avalonia" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Formulario para añadir tarea -->
        <Grid Margin="0,0,0,20" ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0"
                     Watermark="Escribe una nueva tarea..."
                     Text="{Binding NuevaTarea}"
                     VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="➕ Añadir"
                    Command="{Binding AgregarTareaCommand}"
                    Margin="10,0,0,0"
                    Padding="15,8"/>
        </Grid>

        <!-- Lista de tareas -->
        <ItemsControl ItemsSource="{Binding Tareas}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#F5F5F5" 
                            CornerRadius="5" 
                            Padding="10" 
                            Margin="0,5">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding Completada}"
                                      VerticalAlignment="Center"
                                      Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).ToggleTareaCommand}"
                                      CommandParameter="{Binding}"/>
                            
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Titulo}"
                                       VerticalAlignment="Center"
                                       Margin="10,0">
                                <TextBlock.Styles>
                                    <Style Selector="TextBlock">
                                        <Style Selector="TextBlock:pointer">
                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Style>
                                    </Style>
                                </TextBlock.Styles>
                            </TextBlock>
                            
                            <Button Grid.Column="2"
                                    Content="🗑️"
                                    Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).EliminarTareaCommand}"
                                    CommandParameter="{Binding}"
                                    Padding="5"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Contador -->
        <Border Background="#E0E0E0" CornerRadius="5" Padding="10" Margin="0,20,0,0">
            <TextBlock HorizontalAlignment="Center">
                <Run Text="📊 Tareas pendientes: "/>
                <Run Text="{Binding Pendientes}" FontWeight="Bold"/>
            </TextBlock>
        </Border>
    </StackPanel>
</Window>