<Page x:Class="GestionAcademica.Views.Estudiantes.EstudiantesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Estudiantes"
      Background="#1E1E1E">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Gestión de Estudiantes" 
                   Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#252525" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <WrapPanel>
                <Button Content="+ Nuevo" Command="{Binding NewCommand}" 
                        Background="#667EEA" Foreground="White" BorderThickness="0" 
                        Padding="20,10" Cursor="Hand" Margin="0,0,10,0" FontWeight="Bold"
                        MinWidth="120">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" 
                                    Padding="{TemplateBinding Padding}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Editar" Command="{Binding EditCommand}" 
                        Background="#3C3C3C" Foreground="White" BorderThickness="0" 
                        Padding="20,10" Cursor="Hand" Margin="0,0,10,0"
                        IsEnabled="{Binding SelectedEstudiante, Converter={StaticResource NullToBoolConverter}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" 
                                    Padding="{TemplateBinding Padding}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Eliminar" Command="{Binding DeleteCommand}" 
                        Background="#DC3545" Foreground="White" BorderThickness="0" 
                        Padding="20,10" Cursor="Hand" Margin="0,0,30,0"
                        IsEnabled="{Binding SelectedEstudiante, Converter={StaticResource NullToBoolConverter}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" 
                                    Padding="{TemplateBinding Padding}" BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <TextBlock Text="Buscar:" VerticalAlignment="Center" Foreground="#CCCCCC" Margin="0,0,10,0" FontSize="14"/>
                <TextBox Width="300" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Background="#1E1E1E" Foreground="White" BorderBrush="#555555" BorderThickness="1" 
                         Padding="10,8" FontSize="14"/>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid -->
            <DataGrid Grid.Column="0" ItemsSource="{Binding Estudiantes}" 
                      SelectedItem="{Binding SelectedEstudiante}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Background="#252525"
                      Foreground="White"
                      BorderBrush="#3C3C3C"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#3C3C3C"
                      RowBackground="#252525"
                      AlternatingRowBackground="#2A2A2A"
                      SelectionUnit="FullRow"
                      Margin="0,0,20,0"
                      FontSize="13">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#4A4A6A"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="12,12"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="BorderBrush" Value="#3C3C3C"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#5A5A7A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#5A5A7A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Foto" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="40" Height="40" CornerRadius="20" Background="#3C3C3C" Cursor="Hand">
                                    <Image Source="{Binding Imagen, Converter={StaticResource ImagePathConverter}}" 
                                           Stretch="UniformToFill"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="DNI" Binding="{Binding Dni}" Width="100"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="*"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                    <DataGridTextColumn Header="Ciclo" Binding="{Binding Ciclo}" Width="100"/>
                    <DataGridTextColumn Header="Nota" Binding="{Binding Calificacion, StringFormat=F2}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Edit Form Panel -->
            <Border Grid.Column="1" Width="450" 
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="#252525"
                    BorderBrush="#667EEA"
                    BorderThickness="2"
                    CornerRadius="10" 
                    Padding="25">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Datos del Estudiante" 
                                   Foreground="White" FontSize="22" FontWeight="Bold" 
                                   Margin="0,0,0,25"/>

                        <!-- Image -->
                        <Border Width="120" Height="120" CornerRadius="60" 
                                Background="#3C3C3C" 
                                HorizontalAlignment="Center" Margin="0,0,0,25"
                                Cursor="Hand"
                                MouseLeftButtonDown="OnPhotoClick">
                            <Grid>
                                <Image Source="{Binding EditingEstudiante.Imagen, Converter={StaticResource ImagePathConverter}}" 
                                       Stretch="UniformToFill"/>
                            </Grid>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Nombre *" Foreground="#CCCCCC" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditingEstudiante.Nombre, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="#1E1E1E" Foreground="White" BorderBrush="#555555" BorderThickness="1" 
                                         Padding="10,10" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Apellidos *" Foreground="#CCCCCC" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditingEstudiante.Apellidos, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="#1E1E1E" Foreground="White" BorderBrush="#555555" BorderThickness="1" 
                                         Padding="10,10" FontSize="14"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DNI *" Foreground="#CCCCCC" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditingEstudiante.Dni, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="#1E1E1E" Foreground="White" BorderBrush="#555555" BorderThickness="1" 
                                         Padding="10,10" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Nota *" Foreground="#CCCCCC" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditingEstudiante.Calificacion, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="#1E1E1E" Foreground="White" BorderBrush="#555555" BorderThickness="1" 
                                         Padding="10,10" FontSize="14"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Ciclo" Foreground="#CCCCCC" FontSize="13" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding Ciclos}" 
                                          SelectedItem="{Binding EditingEstudiante.Ciclo}" 
                                          Background="#1E1E1E"
                                          Foreground="White"
                                          BorderBrush="#555555"
                                          BorderThickness="1"
                                          Padding="10,8"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Curso" Foreground="#CCCCCC" FontSize="13" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding Cursos}" 
                                          SelectedItem="{Binding EditingEstudiante.Curso}" 
                                          Background="#1E1E1E"
                                          Foreground="White"
                                          BorderBrush="#555555"
                                          BorderThickness="1"
                                          Padding="10,8"/>
                            </StackPanel>
                        </Grid>

                        <Button Content="Guardar Estudiante" Command="{Binding SaveCommand}" 
                                Background="#667EEA" Foreground="White" BorderThickness="0" 
                                Padding="20,15" Cursor="Hand" Margin="0,30,0,10" FontSize="15" FontWeight="Bold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" 
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="Cancelar" Command="{Binding CancelCommand}" 
                                Background="#3C3C3C" Foreground="White" BorderThickness="0"
                                Padding="20,12" Cursor="Hand" FontSize="14">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" 
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#252525" CornerRadius="5" Padding="15,10" Margin="0,15,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#AAAAAA" FontSize="13"/>
        </Border>
    </Grid>
</Page>