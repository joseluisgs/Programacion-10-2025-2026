<Page x:Class="GestionAcademica.Views.Estudiantes.EstudiantesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Gestión Académica - Estudiantes"
      Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <Grid>
        <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="👨‍🎓 Gestión de Estudiantes" 
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <WrapPanel>
                <Button Content="➕ Nuevo" Command="{Binding NewCommand}" 
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,5,0" FontWeight="Bold"
                        ToolTip="Crear nuevo estudiante" MinWidth="80"/>
                <Button Content="👁️ Ver" Command="{Binding ViewCommand}" 
                        Style="{StaticResource InfoButton}"
                        Margin="0,0,5,0"
                        IsEnabled="{Binding SelectedEstudiante, Converter={StaticResource NullToBoolConverter}}"
                        ToolTip="Ver detalles del estudiante" MinWidth="70"/>
                <Button Content="✏️ Editar" Command="{Binding EditCommand}" 
                        Style="{StaticResource WarningButton}"
                        Margin="0,0,5,0"
                        IsEnabled="{Binding SelectedEstudiante, Converter={StaticResource NullToBoolConverter}}"
                        ToolTip="Editar estudiante seleccionado" MinWidth="70"/>
                <Button Command="{Binding DeleteCommand}" 
                        Margin="0,0,5,0"
                        MinWidth="80">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                            <Setter Property="Content" Value="🗑️ Eliminar"/>
                            <Setter Property="ToolTip" Value="Eliminar estudiante seleccionado"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding UsaBorradoLogico}" Value="True"/>
                                        <Condition Binding="{Binding SelectedEstudiante.IsDeleted}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Content" Value="♻️ Restaurar"/>
                                    <Setter Property="ToolTip" Value="Restaurar estudiante eliminado"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="🔄 Recargar" Command="{Binding LoadCommand}" 
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,15,0"
                        ToolTip="Recargar lista desde el repositorio" MinWidth="80"/>
                
                <TextBlock Text="Buscar:" VerticalAlignment="Center" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,5,0" FontSize="14"/>
                <TextBox Width="116" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" 
                         Padding="8,6" FontSize="14" Margin="0,0,8,0"/>
                
                <TextBlock Text="Ciclo:" VerticalAlignment="Center" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,5,0" FontSize="14"/>
                <ComboBox ItemsSource="{Binding CiclosConTodos}" 
                          SelectedItem="{Binding CicloSeleccionado}"
                          Width="90"
                          Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" 
                          Padding="6,5" FontSize="14" Margin="0,0,8,0"/>
                
                <CheckBox Content="Ver eliminados" IsChecked="{Binding MostrarEliminados}" 
                          VerticalAlignment="Center"
                          FontSize="14" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                          Visibility="{Binding UsaBorradoLogico, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="2">
            <!-- DataGrid ocupando todo el espacio -->
            <DataGrid ItemsSource="{Binding Estudiantes}" 
                      SelectedItem="{Binding SelectedEstudiante}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                      Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                      BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                      RowBackground="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                      AlternatingRowBackground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
                      SelectionUnit="FullRow"
                      FontSize="13"
                      MouseDoubleClick="OnEstudianteDoubleClick">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
                        <Setter Property="Padding" Value="12,12"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="FontStyle" Value="Italic"/>
                                <Setter Property="Foreground" Value="Gray"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Foto" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" Cursor="Hand">
                                    <Image Source="{Binding Imagen, Converter={StaticResource ImagePathConverter}}" 
                                           Stretch="UniformToFill"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="DNI" Binding="{Binding Dni}" Width="100"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="*"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                    <DataGridTextColumn Header="Ciclo" Binding="{Binding Ciclo}" Width="100"/>
                    <DataGridTextColumn Header="Nota" Binding="{Binding Calificacion, StringFormat=F2}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Paginación -->
        <Border Grid.Row="3" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" CornerRadius="5" Padding="15,10" Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="⏮" Command="{Binding PrimeraPaginaCommand}" 
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="35" Margin="0,0,5,0"
                        ToolTip="Primera página"/>
                <Button Content="◀" Command="{Binding PaginaAnteriorCommand}" 
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="35" Margin="0,0,5,0"
                        ToolTip="Página anterior"/>
                
                <TextBlock Text="{Binding PaginaActual}" VerticalAlignment="Center" 
                           FontSize="14" FontWeight="Bold" Margin="5,0"/>
                <TextBlock Text=" / " VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                <TextBlock Text="{Binding TotalPaginas}" VerticalAlignment="Center" 
                           FontSize="14" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="5,0"/>

                <Button Content="▶" Command="{Binding PaginaSiguienteCommand}" 
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="35" Margin="5,0,5,0"
                        ToolTip="Página siguiente"/>
                <Button Content="⏭" Command="{Binding UltimaPaginaCommand}" 
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="35" Margin="0,0,15,0"
                        ToolTip="Última página"/>

                <TextBlock Text="Mostrar:" VerticalAlignment="Center" 
                           FontSize="13" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,5,0"/>
                <ComboBox ItemsSource="{Binding TamanosPagina}" 
                          SelectedItem="{Binding TamanoPagina}"
                          Width="60" VerticalAlignment="Center"
                          Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" 
                          Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" 
                          BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" 
                          Padding="4,3" FontSize="13"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" CornerRadius="5" Padding="15,10" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="13"/>
        </Border>
        </Grid>

        <!-- ProgressBar de Loading -->
        <Border Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="300"
                             Height="8"
                             Foreground="#667EEA"/>
                <TextBlock Text="Cargando..."
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>