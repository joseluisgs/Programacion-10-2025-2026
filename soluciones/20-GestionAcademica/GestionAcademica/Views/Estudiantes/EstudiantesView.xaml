<Page x:Class="GestionAcademica.Views.Estudiantes.EstudiantesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Estudiantes"
      Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Gestión de Estudiantes" 
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <WrapPanel>
                <Button Content="+ Nuevo" Command="{Binding NewCommand}" 
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,10,0" FontWeight="Bold"/>
                <Button Content="Editar" Command="{Binding EditCommand}" 
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,10,0"
                        IsEnabled="{Binding SelectedEstudiante, Converter={StaticResource NullToBoolConverter}}"/>
                <Button Content="Eliminar" Command="{Binding DeleteCommand}" 
                        Style="{StaticResource DangerButton}"
                        Margin="0,0,30,0"
                        IsEnabled="{Binding SelectedEstudiante, Converter={StaticResource NullToBoolConverter}}"/>
                
                <TextBlock Text="Buscar:" VerticalAlignment="Center" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,10,0" FontSize="14"/>
                <TextBox Width="300" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" 
                         Padding="10,8" FontSize="14"/>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid -->
            <DataGrid Grid.Column="0" ItemsSource="{Binding Estudiantes}" 
                      SelectedItem="{Binding SelectedEstudiante}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                      Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                      BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                      RowBackground="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                      AlternatingRowBackground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
                      SelectionUnit="FullRow"
                      Margin="0,0,20,0"
                      FontSize="13">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
                        <Setter Property="Padding" Value="12,12"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Foto" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" Cursor="Hand">
                                    <Image Source="{Binding Imagen, Converter={StaticResource ImagePathConverter}}" 
                                           Stretch="UniformToFill"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="DNI" Binding="{Binding Dni}" Width="100"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="*"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                    <DataGridTextColumn Header="Ciclo" Binding="{Binding Ciclo}" Width="100"/>
                    <DataGridTextColumn Header="Nota" Binding="{Binding Calificacion, StringFormat=F2}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Edit Form Panel -->
            <Border Grid.Column="1" Width="450" 
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"
                    BorderThickness="2"
                    CornerRadius="10" 
                    Padding="25">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Datos del Estudiante" 
                                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" FontSize="22" FontWeight="Bold" 
                                   Margin="0,0,0,25"/>

                        <!-- Image -->
                        <Border Width="120" Height="120" CornerRadius="60" 
                                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" 
                                HorizontalAlignment="Center" Margin="0,0,0,25"
                                Cursor="Hand"
                                MouseLeftButtonDown="OnPhotoClick">
                            <Grid>
                                <Image Source="{Binding EditingEstudiante.Imagen, Converter={StaticResource ImagePathConverter}}" 
                                       Stretch="UniformToFill"/>
                            </Grid>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Nombre *" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditingEstudiante.Nombre, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" 
                                         Padding="10,10" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Apellidos *" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditingEstudiante.Apellidos, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" 
                                         Padding="10,10" FontSize="14"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DNI *" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditingEstudiante.Dni, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" 
                                         Padding="10,10" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Nota *" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EditingEstudiante.Calificacion, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" 
                                         Padding="10,10" FontSize="14"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Ciclo" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="13" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding Ciclos}" 
                                          SelectedItem="{Binding EditingEstudiante.Ciclo}" 
                                          Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                                          Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                          BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                          BorderThickness="1"
                                          Padding="10,8"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Curso" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="13" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding Cursos}" 
                                          SelectedItem="{Binding EditingEstudiante.Curso}" 
                                          Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                                          Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                          BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                          BorderThickness="1"
                                          Padding="10,8"/>
                            </StackPanel>
                        </Grid>

                        <Button Content="Guardar Estudiante" Command="{Binding SaveCommand}" 
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,30,0,10" FontSize="15" FontWeight="Bold"/>
                        <Button Content="Cancelar" Command="{Binding CancelCommand}" 
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,0,0" FontSize="14"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" CornerRadius="5" Padding="15,10" Margin="0,15,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="13"/>
        </Border>
    </Grid>
</Page>