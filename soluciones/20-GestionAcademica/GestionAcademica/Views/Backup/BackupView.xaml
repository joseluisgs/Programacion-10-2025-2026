<Page x:Class="GestionAcademica.Views.Backup.BackupView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Backups"
      Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="💾 Copias de Seguridad" 
                   Style="{DynamicResource HeaderLabel}" Margin="0,0,0,20"/>

        <!-- Actions -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="Crear Backup" Command="{Binding RealizarBackupCommand}" 
                    Style="{DynamicResource PrimaryButton}" Margin="0,0,10,0"/>
            <Button Content="Refrescar" Command="{Binding RefreshCommand}" 
                    Style="{DynamicResource SecondaryButton}" Margin="0,0,10,0"/>
        </StackPanel>

        <!-- Backup List -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" ItemsSource="{Binding Backups}" 
                     SelectedItem="{Binding SelectedBackup}"
                     Style="{DynamicResource ListBoxStyle}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Padding="5"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <Button Content="Restaurar" Command="{Binding RestaurarBackupCommand}" 
                        Style="{DynamicResource PrimaryButton}" Margin="0,0,0,10"/>
                <Button Content="Eliminar" Command="{Binding EliminarBackupCommand}" 
                        Style="{DynamicResource DangerButton}"/>
            </StackPanel>
        </Grid>

        <!-- Status Bar -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" 
                   Style="{DynamicResource StatusLabel}" Margin="0,10,0,0"/>
    </Grid>
</Page>