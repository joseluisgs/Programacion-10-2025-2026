<Window x:Class="GestionAcademica.Views.Docentes.DocenteDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalles del Docente"
        Width="800" Height="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/icons/app-icon.png"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="👨‍🏫 Detalles del Docente"
                   FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                   Margin="0,0,0,20"/>

        <!-- Imagen circular -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Border Width="120" Height="120" CornerRadius="60"
                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
                <Border.Clip>
                    <EllipseGeometry Center="60,60" RadiusX="60" RadiusY="60"/>
                </Border.Clip>
                <Grid>
                    <Image Source="{Binding Docente.Imagen, Converter={StaticResource ImagePathConverter}}"
                           Stretch="UniformToFill"/>
                    <TextBlock Text="Sin imagen"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               FontSize="11"
                               Visibility="{Binding Docente.Imagen, Converter={StaticResource NullToVisibilityConverter}}"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Formulario en 2 columnas (solo lectura) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- DNI -->
            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,15">
                <TextBlock Text="DNI" FontSize="12" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Docente.Dni, Mode=OneWay}" IsReadOnly="True"
                         Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                         Padding="10,8" FontSize="14"/>
            </StackPanel>

            <!-- Email -->
            <StackPanel Grid.Row="0" Grid.Column="2" Margin="10,0,0,15">
                <TextBlock Text="Email" FontSize="12" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Docente.Email, Mode=OneWay}" IsReadOnly="True"
                         Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                         Padding="10,8" FontSize="14"/>
            </StackPanel>

            <!-- Nombre -->
            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,15">
                <TextBlock Text="Nombre" FontSize="12" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Docente.Nombre, Mode=OneWay}" IsReadOnly="True"
                         Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                         Padding="10,8" FontSize="14"/>
            </StackPanel>

            <!-- Apellidos -->
            <StackPanel Grid.Row="1" Grid.Column="2" Margin="10,0,0,15">
                <TextBlock Text="Apellidos" FontSize="12" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Docente.Apellidos, Mode=OneWay}" IsReadOnly="True"
                         Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                         Padding="10,8" FontSize="14"/>
            </StackPanel>

            <!-- Especialidad -->
            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,15">
                <TextBlock Text="Especialidad" FontSize="12" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Docente.Especialidad, Mode=OneWay}" IsReadOnly="True"
                         Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                         Padding="10,8" FontSize="14"/>
            </StackPanel>

            <!-- Fecha Nacimiento -->
            <StackPanel Grid.Row="2" Grid.Column="2" Margin="10,0,0,15">
                <TextBlock Text="Fecha de Nacimiento" FontSize="12" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Docente.FechaNacimiento, StringFormat=dd/MM/yyyy, Mode=OneWay}" IsReadOnly="True"
                         Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                         Padding="10,8" FontSize="14"/>
            </StackPanel>

            <!-- Experiencia -->
            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,10,15">
                <TextBlock Text="Experiencia (años)" FontSize="12" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Docente.Experiencia, Mode=OneWay}" IsReadOnly="True"
                         Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                         Padding="10,8" FontSize="14"/>
            </StackPanel>

            <!-- Ciclo -->
            <StackPanel Grid.Row="3" Grid.Column="2" Margin="10,0,0,15">
                <TextBlock Text="Ciclo" FontSize="12" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Docente.Ciclo, Mode=OneWay}" IsReadOnly="True"
                         Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                         Padding="10,8" FontSize="14"/>
            </StackPanel>
        </Grid>

        <!-- Botón cerrar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cerrar" Click="OnCerrarClick" 
                    Style="{StaticResource SecondaryButton}" Width="120"/>
        </StackPanel>
    </Grid>
</Window>