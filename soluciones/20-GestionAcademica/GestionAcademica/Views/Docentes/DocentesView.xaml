<Page x:Class="GestionAcademica.Views.Docentes.DocentesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Gestión Académica - Docentes"
      Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <Grid>
        <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="👨‍🏫 Gestión de Docentes" 
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <WrapPanel>
                <Button Content="➕ Nuevo" Command="{Binding NewCommand}" 
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,10,0" FontWeight="Bold"
                        ToolTip="Crear nuevo docente"/>
                <Button Content="✏️ Editar" Command="{Binding EditCommand}" 
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,10,0"
                        IsEnabled="{Binding SelectedDocente, Converter={StaticResource NullToBoolConverter}}"
                        ToolTip="Editar docente seleccionado"/>
                <Button Content="🗑️ Eliminar" Command="{Binding DeleteCommand}" 
                        Style="{StaticResource DangerButton}"
                        Margin="0,0,10,0"
                        IsEnabled="{Binding SelectedDocente, Converter={StaticResource NullToBoolConverter}}"
                        ToolTip="Eliminar docente seleccionado"/>
                <Button Content="🔄 Recargar" Command="{Binding LoadCommand}" 
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,30,0"
                        ToolTip="Recargar lista desde el repositorio"/>
                
                <TextBlock Text="Buscar:" VerticalAlignment="Center" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,10,0" FontSize="14"/>
                <TextBox Width="300" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" 
                         Padding="10,8" FontSize="14"/>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="2">
            <!-- DataGrid ocupando todo el espacio -->
            <DataGrid ItemsSource="{Binding Docentes}" 
                      SelectedItem="{Binding SelectedDocente}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                      RowBackground="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" AlternatingRowBackground="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
                      SelectionUnit="FullRow">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
                        <Setter Property="Padding" Value="12"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Foto" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="40" Height="40" CornerRadius="20" Margin="5" ClipToBounds="True">
                                    <Image Source="{Binding Imagen, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="DNI" Binding="{Binding Dni}" Width="100"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="*"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                    <DataGridTextColumn Header="Ciclo" Binding="{Binding Ciclo}" Width="100"/>
                    <DataGridTextColumn Header="Especialidad" Binding="{Binding Especialidad}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Row="3" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" CornerRadius="5" Padding="15,10" Margin="0,15,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="13"/>
        </Border>
        </Grid>

        <!-- ProgressBar de Loading -->
        <Border Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="300"
                             Height="8"
                             Foreground="#667EEA"/>
                <TextBlock Text="Cargando..."
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>