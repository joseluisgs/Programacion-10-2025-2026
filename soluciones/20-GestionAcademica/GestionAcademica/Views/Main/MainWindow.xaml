<Window x:Class="GestionAcademica.Views.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        
        Title="Gestión Académica - DAW"
        Icon="pack://application:,,,/Resources/icons/app-icon.png"
        Width="1200"
        Height="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Padding="5">
            <MenuItem Header="_Archivo">
                <MenuItem Header="_Exportar datos..." Click="OnExportarClick">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Export" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Importar datos..." Click="OnImportarClick">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Import" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Crear backup..." Click="OnCrearBackupClick">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="BackupRestore" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Restaurar backup..." Click="OnRestaurarBackupClick">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Restore" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Salir" Click="OnSalirClick">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ExitToApp" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            
            <MenuItem Header="_Personas">
                <MenuItem Header="_Estudiantes" Click="OnEstudiantesClick">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="School" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Docentes" Click="OnDocentesClick">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="AccountTie" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            
            <MenuItem Header="_Informes">
                <MenuItem Header="_Generar informe..." Click="OnInformesClick">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="FileDocument" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Estadísticas" Click="OnGraficosClick">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="ChartLine" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            
            <MenuItem Header="_Herramientas">
                <MenuItem Header="_Configuración" Click="OnConfiguracionClick">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Cog" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            
            <MenuItem Header="_Ayuda">
                <MenuItem Header="_Acerca de" Click="OnAcercaDeClick">
                    <MenuItem.Icon>
                        <iconPacks:PackIconMaterial Kind="Information" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="0,0,1,0">
                <StackPanel Margin="10">
                    <TextBlock Text="NAVEGACIÓN" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="10,10,0,10"/>
                    
                    <Button Click="OnDashboardClick" Margin="0,2" Padding="15,10" HorizontalContentAlignment="Left" Background="Transparent" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" BorderThickness="0"
                            ToolTip="Ver panel de control">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconModern Kind="Home" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OnEstudiantesClick" Margin="0,2" Padding="15,10" HorizontalContentAlignment="Left" Background="Transparent" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" BorderThickness="0"
                            ToolTip="Ver gestión de estudiantes">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="School" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Estudiantes" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OnDocentesClick" Margin="0,2" Padding="15,10" HorizontalContentAlignment="Left" Background="Transparent" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" BorderThickness="0"
                            ToolTip="Ver gestión de docentes">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="AccountTie" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Docentes" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Separator Margin="10,15" Background="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>
                    
                    <TextBlock Text="HERRAMIENTAS" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="10,0,0,10"/>
                    
                    <Button Click="OnInformesClick" Margin="0,2" Padding="15,10" HorizontalContentAlignment="Left" Background="Transparent" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" BorderThickness="0"
                            ToolTip="Ver generación de informes">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FileDocument" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Informes" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OnGraficosClick" Margin="0,2" Padding="15,10" HorizontalContentAlignment="Left" Background="Transparent" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" BorderThickness="0"
                            ToolTip="Ver gráficos y estadísticas">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ChartBar" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Gráficos" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OnBackupClick" Margin="0,2" Padding="15,10" HorizontalContentAlignment="Left" Background="Transparent" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" BorderThickness="0"
                            ToolTip="Ver gestión de copias de seguridad">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Database" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Backups" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="OnImportExportClick" Margin="0,2" Padding="15,10" HorizontalContentAlignment="Left" Background="Transparent" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" BorderThickness="0"
                            ToolTip="Ver importación y exportación de datos">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="SwapHorizontal" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Import/Export" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Content Area -->
            <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Padding="5">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Listo" FontSize="12"/>
            </StatusBarItem>
            <Separator Background="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>
            <StatusBarItem>
                <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" FontSize="12" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="DeleteTypeText" FontSize="12" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>