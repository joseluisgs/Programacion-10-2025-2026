<Page x:Class="GestionAcademica.Views.Graficos.GraficosView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wpf="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
      Title="Gráficos"
      Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="📉 Gráficos y Estadísticas" 
                   Style="{DynamicResource HeaderLabel}" Margin="0,0,0,20"/>

        <!-- Stats Summary -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,20">
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,10,10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Total Estudiantes" Style="{DynamicResource LabelStyle}"/>
                    <TextBlock Text="{Binding TotalEstudiantes}" Style="{DynamicResource ValueStyle}" FontSize="24"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,10,10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Total Docentes" Style="{DynamicResource LabelStyle}"/>
                    <TextBlock Text="{Binding TotalDocentes}" Style="{DynamicResource ValueStyle}" FontSize="24"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,10,10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Media Notas" Style="{DynamicResource LabelStyle}"/>
                    <TextBlock Text="{Binding MediaNotas, StringFormat=F2}" Style="{DynamicResource ValueStyle}" FontSize="24"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,10,10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Aprobados" Style="{DynamicResource LabelStyle}"/>
                    <TextBlock Text="{Binding EstudiantesAprobados}" Style="{DynamicResource ValueStyle}" FontSize="24"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource CardStyle}" Margin="0,0,10,10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Suspensos" Style="{DynamicResource LabelStyle}"/>
                    <TextBlock Text="{Binding EstudiantesSuspensos}" Style="{DynamicResource ValueStyle}" FontSize="24"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Grid de 4 gráficos en 2x2 -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Gráfico 1: Notas medias por ciclo -->
            <Border Grid.Row="0" Grid.Column="0" 
                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="1" CornerRadius="8" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="📊 Notas medias por ciclo" 
                               FontSize="14" FontWeight="SemiBold" Margin="5,0,0,10"
                               Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                    <wpf:WpfPlot Grid.Row="1" x:Name="NotasChart"/>
                </Grid>
            </Border>

            <!-- Gráfico 2: Distribución de calificaciones -->
            <Border Grid.Row="0" Grid.Column="2" 
                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="1" CornerRadius="8" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="🥧 Distribución de calificaciones" 
                               FontSize="14" FontWeight="SemiBold" Margin="5,0,0,10"
                               Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                    <wpf:WpfPlot Grid.Row="1" x:Name="DistributionChart"/>
                </Grid>
            </Border>

            <!-- Gráfico 3: Personas por ciclo -->
            <Border Grid.Row="2" Grid.Column="0" 
                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="1" CornerRadius="8" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="👥 Estudiantes y Docentes por ciclo" 
                               FontSize="14" FontWeight="SemiBold" Margin="5,0,0,10"
                               Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                    <wpf:WpfPlot Grid.Row="1" x:Name="CiclosChart"/>
                </Grid>
            </Border>

            <!-- Gráfico 4: Estudiantes por edad -->
            <Border Grid.Row="2" Grid.Column="2" 
                    Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                    BorderThickness="1" CornerRadius="8" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="🎂 Estudiantes por rango de edad" 
                               FontSize="14" FontWeight="SemiBold" Margin="5,0,0,10"
                               Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                    <wpf:WpfPlot Grid.Row="1" x:Name="EdadChart"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" 
                   Style="{DynamicResource StatusLabel}" Margin="0,10,0,0"/>
    </Grid>
</Page>