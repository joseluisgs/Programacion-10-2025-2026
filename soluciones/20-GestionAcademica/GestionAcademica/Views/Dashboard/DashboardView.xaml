<Page x:Class="GestionAcademica.Views.Dashboard.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard"
      Background="#1E1E1E">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Panel de Control" 
                   Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="#252525" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" Foreground="#667EEA" Margin="0,0,0,10"/>
                <UniformGrid Columns="3">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="ESTUDIANTES" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalEstudiantes}" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="DOCENTES" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalDocentes}" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="ESTADO" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center"/>
                        <TextBlock Text="ACTIVO" Foreground="#28A745" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </UniformGrid>
                <TextBlock Text="────────────────────────────────────────────────────────────────────────" Foreground="#333333" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#252525" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="RESUMEN ACADÉMICO" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                    <TextBlock Text="{Binding MensajeEstado}" Foreground="#AAAAAA" TextWrapping="Wrap"/>
                    
                    <Grid Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="Distribución de Notas:" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                            <ProgressBar Value="{Binding PorcentajeAprobados}" Height="10" Foreground="#667EEA" Background="#1E1E1E" BorderThickness="0"/>
                            <TextBlock Text="{Binding PorcentajeAprobados, StringFormat={}{0}% aprobados}" Foreground="#AAAAAA" FontSize="11" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#252525" CornerRadius="8" Padding="20" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="ACCIONES RÁPIDAS" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                    <Button Content="Refrescar Datos" Command="{Binding RefrescarCommand}" Padding="15,10" Background="#3C3C3C" Foreground="White" BorderThickness="0" Margin="0,0,0,10"/>
                    <Button Content="Ver Gráficos" Command="{Binding ViewGraficosCommand}" Padding="15,10" Background="#3C3C3C" Foreground="White" BorderThickness="0" Margin="0,0,0,10"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>