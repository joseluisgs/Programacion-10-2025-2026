<Window x:Class="GestionAcademica.Views.Dialog.DocenteEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="800" Height="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="{Binding WindowTitle}"
                   FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                   Margin="0,0,0,20"/>

        <!-- Imagen circular clickeable -->
        <Border Grid.Row="1" Width="120" Height="120" CornerRadius="60"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                HorizontalAlignment="Center" Margin="0,0,0,20"
                Cursor="Hand"
                MouseLeftButtonDown="OnPhotoClick">
            <Border.Clip>
                <EllipseGeometry Center="60,60" RadiusX="60" RadiusY="60"/>
            </Border.Clip>
            <Image Source="{Binding FormData.Imagen, Converter={StaticResource ImagePathConverter}}"
                   Stretch="UniformToFill"/>
        </Border>

        <!-- Formulario en 2 columnas -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Columna izquierda -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Nombre *" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="13" Margin="0,0,0,5"/>
                <TextBox Text="{Binding FormData.Nombre, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                         BorderThickness="1" Padding="10,10" FontSize="14" Margin="0,0,0,15"/>

                <TextBlock Text="Apellidos *" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="13" Margin="0,0,0,5"/>
                <TextBox Text="{Binding FormData.Apellidos, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                         BorderThickness="1" Padding="10,10" FontSize="14" Margin="0,0,0,15"/>

                <TextBlock Text="DNI *" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="13" Margin="0,0,0,5"/>
                <TextBox Text="{Binding FormData.Dni, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                         BorderThickness="1" Padding="10,10" FontSize="14" Margin="0,0,0,15"/>

                <TextBlock Text="Email *" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="13" Margin="0,0,0,5"/>
                <TextBox Text="{Binding FormData.Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                         BorderThickness="1" Padding="10,10" FontSize="14" Margin="0,0,0,15"/>
            </StackPanel>

            <!-- Columna derecha -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Fecha de Nacimiento *" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="13" Margin="0,0,0,5"/>
                <DatePicker SelectedDate="{Binding FormData.FechaNacimiento, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                            Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                            Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                            BorderThickness="1" Padding="10,8" FontSize="14" Margin="0,0,0,15"/>

                <TextBlock Text="Especialidad *" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="13" Margin="0,0,0,5"/>
                <TextBox Text="{Binding FormData.Especialidad, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                         BorderThickness="1" Padding="10,10" FontSize="14" Margin="0,0,0,15"/>

                <TextBlock Text="Experiencia (años)" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="13" Margin="0,0,0,5"/>
                <TextBox Text="{Binding FormData.Experiencia, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                         Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                         Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                         BorderThickness="1" Padding="10,10" FontSize="14" Margin="0,0,0,15"/>

                <TextBlock Text="Ciclo" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="13" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding Ciclos}"
                          SelectedItem="{Binding FormData.Ciclo}"
                          Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                          Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                          BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                          BorderThickness="1" Padding="10,8" FontSize="14" Margin="0,0,0,15"/>
            </StackPanel>
        </Grid>

        <!-- Botones -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancelar" Command="{Binding CancelCommand}"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,10,0"/>
            <Button Content="💾 Guardar" Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
