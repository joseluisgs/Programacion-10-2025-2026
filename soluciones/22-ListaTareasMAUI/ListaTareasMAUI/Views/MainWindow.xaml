<Window x:Class="ListaTareasMAUI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ListaTareasMAUI.Views"
        Title="Lista de Tareas" Height="500" Width="600"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Estilo para botones principales -->
        <Style x:Key="BotonEstilo" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <!-- Estilo para botón eliminar -->
        <Style x:Key="BotonEliminar" TargetType="Button" BasedOn="{StaticResource BotonEstilo}">
            <Setter Property="Background" Value="#E81123"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
    </Window.Resources>

    <!-- ============================================================
         CONTENEDOR PRINCIPAL
         ============================================================
         
         Grid organiza los elementos en filas y columnas.
         Margin añade espacios alrededor del contenedor.
    -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título de la aplicación -->
        <TextBlock Grid.Row="0" 
                   Text="📝 Lista de Tareas" 
                   FontSize="28" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- ============================================================
             FORMULARIO PARA AÑADIR NUEVA TAREA
             ============================================================
             
             Binding con el ViewModel:
             - TextBox.Text bindea con NuevaTarea (TwoWay)
             - Button.Command bindea con AgregarTareaCommand
             
             TwoWay binding en WPF:
             - Cuando el usuario escribe, se actualiza NuevaTarea en el ViewModel
             - Cuando el código cambia NuevaTarea, se actualiza el TextBox
        -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBox Grid.Column="0"
                     Text="{Binding NuevaTarea, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center"
                     Padding="10"/>
            
            <Button Grid.Column="1"
                    Content="➕ Añadir"
                    Style="{StaticResource BotonEstilo}"
                    Command="{Binding AgregarTareaCommand}"
                    Margin="10,0,0,0"/>
        </Grid>

        <!-- ============================================================
             LISTA DE TAREAS
             ============================================================
             
             ListView muestra la lista de tareas.
             ItemsSource bindea con la colección Tareas del ViewModel.
             SelectionMode="None" desactiva la selección.
             
             x:Name="ListaTareas" permite referenciar el ListView.
        -->
        <ListView x:Name="ListaTareas" 
                  Grid.Row="2"
                  ItemsSource="{Binding Tareas}" 
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <!-- DataTemplate define cómo renderizar cada tarea -->
                <DataTemplate>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- ============================================================
                             CHECKBOX PARA COMPLETAR
                             ============================================================
                             
                             Binding del CheckBox con la propiedad Completada.
                             Event: Checked se conecta con el evento CheckBox_Changed.
                             
                             CommandParameter pasa la tarea al comando.
                             Esto permite saber qué tarea togglear.
                        -->
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding Completada, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  Checked="CheckBox_Changed"
                                  Unchecked="CheckBox_Changed"/>

                        <!-- ============================================================
                             LABEL CON EL TÍTULO
                             ============================================================
                             
                             Binding del Text con la propiedad Titulo.
                             Se usa un trigger para tachar las completadas.
                        -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Titulo}"
                                   VerticalAlignment="Center"
                                   FontSize="16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Completada}" Value="True">
                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            <Setter Property="Foreground" Value="Gray"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- ============================================================
                             BOTÓN DE ELIMINAR
                             ============================================================
                             
                             Command bindea con EliminarTareaCommand.
                             CommandParameter pasa la tarea actual al comando.
                        -->
                        <Button Grid.Column="2"
                                Content="🗑️"
                                Style="{StaticResource BotonEliminar}"
                                Command="{Binding Source={x:Reference ListaTareas}, 
                                                  Path=DataContext.EliminarTareaCommand}"
                                CommandParameter="{Binding}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- ============================================================
             CONTADOR DE TAREAS PENDIENTES
             ============================================================
             
             Muestra el número de tareas pendientes.
             Binding con la propiedad Pendientes del ViewModel.
             
             StringFormat formatea el texto con los valores.
        -->
        <TextBlock Grid.Row="3" 
                   Margin="0,20,0,0"
                   FontSize="16">
            <Run Text="📊 Tareas pendientes: "/>
            <Run Text="{Binding Pendientes}" FontWeight="Bold"/>
            <Run Text=" de "/>
            <Run Text="{Binding Tareas.Count, Mode=OneWay}" FontWeight="Bold"/>
        </TextBlock>
        
    </Grid>
</Window>